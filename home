<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cantinho do Tobias</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;700;800&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{
    --sky:#BEE3F2;
    --sky-deep:#7FB8D9;
    --grass:#8FC97E;
    --grass-deep:#4C7A57;
    --sand:#F4E4C4;
    --sun:#FFD166;
    --coral:#F4785C;
    --shell:#C99B6A;
    --shell-deep:#8B6239;
    --ink:#2E3532;
    --cream:#FBF6EC;
    --radius:26px;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    font-family:'Nunito',sans-serif;
    color:var(--ink);
    background:linear-gradient(180deg,var(--sky) 0%, var(--sky-deep) 32%, var(--grass) 33%, var(--grass-deep) 100%);
    min-height:100vh;
    overflow-x:hidden;
  }
  h1,h2,h3,.display{font-family:'Baloo 2',sans-serif;}
  .wrap{max-width:720px;margin:0 auto;padding:18px 16px 60px;}

  /* header */
  header.top{
    display:flex;align-items:center;justify-content:space-between;
    padding:6px 4px 14px;
  }
  .brand{display:flex;align-items:center;gap:12px;}
  .brand h1{margin:0;font-size:26px;color:var(--grass-deep);text-shadow:0 2px 0 rgba(255,255,255,.4);}
  .brand p{margin:2px 0 0;font-size:14px;font-weight:700;color:#3a5c46;}
  .stars{
    background:var(--cream);border-radius:999px;padding:8px 16px;
    display:flex;align-items:center;gap:6px;font-weight:800;font-size:16px;
    box-shadow:0 4px 0 rgba(0,0,0,.08);
  }

  /* tobias */
  .stage{
    position:relative;background:var(--sand);border-radius:var(--radius);
    padding:20px 16px 26px;box-shadow:0 6px 0 rgba(0,0,0,.08);
    text-align:center;margin-bottom:18px;
  }
  .stage p.speech{
    font-weight:700;font-size:16px;color:var(--grass-deep);margin:10px 0 0;
    min-height:22px;
  }

  /* cards grid */
  .grid{display:grid;grid-template-columns:1fr;gap:14px;}
  @media(min-width:560px){.grid{grid-template-columns:1fr 1fr;}}
  .card{
    background:var(--cream);border-radius:var(--radius);padding:18px;
    box-shadow:0 5px 0 rgba(0,0,0,.08);cursor:pointer;border:none;text-align:left;
    display:flex;flex-direction:column;gap:8px;transition:transform .15s ease;
    font-family:'Nunito',sans-serif;
  }
  .card:hover{transform:translateY(-3px);}
  .card .emoji{font-size:34px;}
  .card h3{margin:0;font-size:19px;color:var(--grass-deep);}
  .card p{margin:0;font-size:14px;color:#4a4a44;font-weight:600;}

  /* sections (games) */
  .screen{display:none;}
  .screen.active{display:block;}
  .backbtn{
    background:none;border:none;font-family:'Nunito';font-weight:800;font-size:15px;
    color:var(--grass-deep);cursor:pointer;padding:8px 2px;margin-bottom:6px;
  }
  .panel{
    background:var(--cream);border-radius:var(--radius);padding:20px 16px;
    box-shadow:0 5px 0 rgba(0,0,0,.08);
  }
  .panel h2{margin:0 0 6px;color:var(--grass-deep);font-size:22px;}
  .msg{font-weight:700;color:#4a4a44;min-height:24px;margin:8px 0;}

  /* simon game */
  .stones{display:grid;grid-template-columns:1fr 1fr;gap:12px;max-width:320px;margin:16px auto;}
  .stone{
    height:100px;border-radius:20px;border:none;cursor:pointer;
    opacity:.85;transition:opacity .1s, transform .1s;
  }
  .stone:active{transform:scale(.96);}
  .stone.lit{opacity:1;box-shadow:0 0 0 6px rgba(255,255,255,.6) inset;}
  .stone.sky{background:var(--sky-deep);}
  .stone.grass{background:var(--grass-deep);}
  .stone.sun{background:var(--sun);}
  .stone.coral{background:var(--coral);}
  .level{font-weight:800;color:var(--grass-deep);}

  /* garden game */
  .pot-wrap{display:flex;flex-direction:column;align-items:center;gap:14px;}
  .duration-choice{display:flex;gap:8px;}
  .duration-choice button{
    border:none;border-radius:999px;padding:8px 16px;font-weight:800;
    background:var(--sky);cursor:pointer;font-family:'Nunito';
  }
  .duration-choice button.selected{background:var(--sun);}
  .plant-scene{width:180px;height:180px;position:relative;}
  .breathe-circle{
    width:110px;height:110px;border-radius:50%;background:radial-gradient(circle at 40% 35%, #fff, var(--sun));
    margin:0 auto;transition:transform 4s ease-in-out;
  }
  .progressbar{width:100%;max-width:300px;height:16px;background:#e6dcc4;border-radius:999px;overflow:hidden;margin:8px auto;}
  .progressbar-fill{height:100%;background:var(--grass-deep);width:0%;transition:width .3s linear;}
  .actionbtn{
    background:var(--grass-deep);color:white;border:none;border-radius:999px;
    padding:12px 26px;font-weight:800;font-size:16px;cursor:pointer;font-family:'Nunito';
    box-shadow:0 4px 0 rgba(0,0,0,.15);
  }
  .actionbtn:disabled{opacity:.5;cursor:not-allowed;}

  /* memory game */
  .memgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;max-width:340px;margin:14px auto;}
  .mcard{
    aspect-ratio:1/1;border-radius:14px;background:var(--sky-deep);
    display:flex;align-items:center;justify-content:center;font-size:26px;cursor:pointer;
    user-select:none;
  }
  .mcard.flipped, .mcard.matched{background:var(--cream);box-shadow:0 0 0 3px var(--sun) inset;}
  .mcard.matched{opacity:.55;cursor:default;}

  /* calm corner floating button */
  .calmfab{
    position:fixed;right:18px;bottom:18px;background:var(--coral);color:white;
    border:none;border-radius:999px;padding:14px 20px;font-weight:800;font-family:'Nunito';
    box-shadow:0 5px 0 rgba(0,0,0,.15);cursor:pointer;z-index:50;font-size:14px;
  }
  .overlay{
    position:fixed;inset:0;background:rgba(46,53,50,.55);display:none;
    align-items:center;justify-content:center;z-index:100;padding:20px;
  }
  .overlay.active{display:flex;}
  .modal{
    background:var(--cream);border-radius:var(--radius);padding:26px 20px;max-width:340px;
    width:100%;text-align:center;
  }
  .modal h3{margin-top:0;color:var(--grass-deep);}
  .closebtn{
    margin-top:14px;background:none;border:2px solid var(--grass-deep);color:var(--grass-deep);
    border-radius:999px;padding:8px 20px;font-weight:800;cursor:pointer;font-family:'Nunito';
  }
</style>
</head>
<body>
<div class="wrap">

  <header class="top">
    <div class="brand">
      <h1>🐢 Cantinho do Tobias</h1>
    </div>
    <div class="stars">⭐ <span id="starCount">0</span></div>
  </header>
  <p style="margin:-8px 0 16px;font-weight:700;color:#3a5c46;">Um lugar para brincar, esperar a nossa vez e treinar a calma</p>

  <div class="stage">
    <svg id="tobiasSvg" width="140" height="120" viewBox="0 0 140 120">
      <ellipse cx="70" cy="95" rx="55" ry="10" fill="rgba(0,0,0,.08)"/>
      <ellipse cx="70" cy="70" rx="50" ry="36" fill="var(--shell)"/>
      <ellipse cx="70" cy="70" rx="50" ry="36" fill="none" stroke="var(--shell-deep)" stroke-width="3"/>
      <g id="shellPatches"></g>
      <circle cx="30" cy="75" r="14" fill="var(--grass)"/>
      <circle cx="18" cy="70" r="9" fill="var(--grass)"/>
      <circle cx="14" cy="70" r="3.4" fill="var(--ink)"/>
      <ellipse cx="108" cy="88" rx="11" ry="8" fill="var(--grass)"/>
      <ellipse cx="45" cy="100" rx="9" ry="7" fill="var(--grass)"/>
      <ellipse cx="95" cy="100" rx="9" ry="7" fill="var(--grass)"/>
    </svg>
    <p class="speech" id="tobiasSpeech">Oi! Eu sou o Tobias. Vamos brincar juntos?</p>
  </div>

  <!-- HOME -->
  <div class="screen active" id="screen-home">
    <div class="grid">
      <button class="card" onclick="openScreen('trilha')">
        <div class="emoji">🪨</div>
        <h3>Trilha das Regras</h3>
        <p>Observe a ordem certinha e repita. Treina seguir instruções.</p>
      </button>
      <button class="card" onclick="openScreen('jardim')">
        <div class="emoji">🌱</div>
        <h3>Jardim da Espera</h3>
        <p>Plante uma sementinha e pratique esperar sua vez.</p>
      </button>
      <button class="card" onclick="openScreen('casco')">
        <div class="emoji">🐌</div>
        <h3>Casco Forte</h3>
        <p>Jogo da memória. Treina continuar tentando quando erra.</p>
      </button>
    </div>
  </div>

  <!-- TRILHA DAS REGRAS (simon) -->
  <div class="screen" id="screen-trilha">
    <button class="backbtn" onclick="openScreen('home')">← Voltar</button>
    <div class="panel">
      <h2>🪨 Trilha das Regras</h2>
      <p class="msg" id="trilhaMsg">Toque em "Começar" e observe a ordem das pedras.</p>
      <p class="level">Nível <span id="trilhaLevel">1</span></p>
      <div class="stones">
        <button class="stone sky" data-c="sky" onclick="stoneClick('sky')"></button>
        <button class="stone grass" data-c="grass" onclick="stoneClick('grass')"></button>
        <button class="stone sun" data-c="sun" onclick="stoneClick('sun')"></button>
        <button class="stone coral" data-c="coral" onclick="stoneClick('coral')"></button>
      </div>
      <div style="text-align:center;">
        <button class="actionbtn" id="trilhaStart" onclick="startTrilha()">Começar</button>
      </div>
    </div>
  </div>

  <!-- JARDIM DA ESPERA -->
  <div class="screen" id="screen-jardim">
    <button class="backbtn" onclick="openScreen('home')">← Voltar</button>
    <div class="panel pot-wrap">
      <h2>🌱 Jardim da Espera</h2>
      <p class="msg" id="jardimMsg">Escolha quanto tempo vamos esperar juntos:</p>
      <div class="duration-choice" id="durationChoice">
        <button onclick="setDuration(10,this)">Curtinho</button>
        <button onclick="setDuration(20,this)" class="selected">Médio</button>
        <button onclick="setDuration(35,this)">Longo</button>
      </div>
      <div class="plant-scene" id="plantScene" style="font-size:70px;display:flex;align-items:flex-end;justify-content:center;">🌱</div>
      <div class="breathe-circle" id="breatheCircle"></div>
      <div class="progressbar"><div class="progressbar-fill" id="jardimBar"></div></div>
      <button class="actionbtn" id="jardimBtn" onclick="plantSeed()">Plantar sementinha</button>
    </div>
  </div>

  <!-- CASCO FORTE (memory) -->
  <div class="screen" id="screen-casco">
    <button class="backbtn" onclick="openScreen('home')">← Voltar</button>
    <div class="panel">
      <h2>🐌 Casco Forte</h2>
      <p class="msg" id="cascoMsg">Encontre os pares. Errar faz parte, é só continuar!</p>
      <div class="memgrid" id="memGrid"></div>
      <div style="text-align:center;">
        <button class="actionbtn" onclick="setupMemory()">Embaralhar de novo</button>
      </div>
    </div>
  </div>

</div>

<button class="calmfab" onclick="openCalm()">🌬️ Cantinho da Calma</button>

<div class="overlay" id="calmOverlay">
  <div class="modal">
    <h3>Vamos respirar juntos</h3>
    <div class="breathe-circle" id="calmCircle" style="margin:20px auto;"></div>
    <p class="msg" id="calmText">Inspire...</p>
    <button class="closebtn" onclick="closeCalm()">Voltar a brincar</button>
  </div>
</div>

<script>
/* ---------- persistence ---------- */
let stars = 0;
let patches = 0;
async function loadProgress(){
  try{
    const r = await window.storage.get('tobias:progress');
    if(r && r.value){
      const d = JSON.parse(r.value);
      stars = d.stars || 0;
    }
  }catch(e){ stars = 0; }
  renderStars();
}
async function saveProgress(){
  try{ await window.storage.set('tobias:progress', JSON.stringify({stars})); }catch(e){}
}
function renderStars(){
  document.getElementById('starCount').textContent = stars;
  patches = Math.min(8, Math.floor(stars/3));
  renderShellPatches();
}
function addStar(n=1){
  stars += n;
  renderStars();
  saveProgress();
}
const patchSpots = [[45,58],[95,58],[35,75],[105,75],[55,85],[85,85],[70,55],[70,80]];
function renderShellPatches(){
  const g = document.getElementById('shellPatches');
  g.innerHTML='';
  for(let i=0;i<patches;i++){
    const [x,y] = patchSpots[i];
    const c = document.createElementNS('http://www.w3.org/2000/svg','circle');
    c.setAttribute('cx',x); c.setAttribute('cy',y); c.setAttribute('r',5);
    c.setAttribute('fill', i%2===0 ? '#F4785C' : '#FFD166');
    g.appendChild(c);
  }
}

/* ---------- screen nav ---------- */
function openScreen(name){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById('screen-'+name).classList.add('active');
  const lines = {
    home:'Oi! Eu sou o Tobias. Vamos brincar juntos?',
    trilha:'Vamos treinar seguir a ordem certinha!',
    jardim:'Esperar também é uma habilidade que a gente treina.',
    casco:'Errar faz parte. O importante é não desistir!'
  };
  document.getElementById('tobiasSpeech').textContent = lines[name] || '';
  if(name==='casco') setupMemory();
  if(name==='trilha') resetTrilha();
}

/* ---------- calm corner ---------- */
let calmInterval;
function openCalm(){
  document.getElementById('calmOverlay').classList.add('active');
  const circle = document.getElementById('calmCircle');
  const text = document.getElementById('calmText');
  let phase = 0;
  const steps = [
    ['Inspire...', 'scale(1.35)'],
    ['Segure...', 'scale(1.35)'],
    ['Solte o ar...', 'scale(0.8)'],
  ];
  function step(){
    text.textContent = steps[phase][0];
    circle.style.transform = steps[phase][1];
    phase = (phase+1) % steps.length;
  }
  step();
  calmInterval = setInterval(step, 4000);
}
function closeCalm(){
  document.getElementById('calmOverlay').classList.remove('active');
  clearInterval(calmInterval);
}

/* ---------- TRILHA DAS REGRAS (simon says) ---------- */
const colors = ['sky','grass','sun','coral'];
let sequence = [];
let userStep = 0;
let level = 1;
let accepting = false;

function resetTrilha(){
  sequence = [];
  level = 1;
  document.getElementById('trilhaLevel').textContent = level;
  document.getElementById('trilhaMsg').textContent = 'Toque em "Começar" e observe a ordem das pedras.';
  document.getElementById('trilhaStart').style.display = 'inline-block';
}
function startTrilha(){
  document.getElementById('trilhaStart').style.display='none';
  sequence = [colors[Math.floor(Math.random()*4)]];
  playSequence();
}
function playSequence(){
  accepting = false;
  userStep = 0;
  document.getElementById('trilhaMsg').textContent = 'Observe com atenção...';
  let i = 0;
  const interval = setInterval(()=>{
    lightStone(sequence[i]);
    i++;
    if(i>=sequence.length){
      clearInterval(interval);
      setTimeout(()=>{
        accepting = true;
        document.getElementById('trilhaMsg').textContent = 'Agora é sua vez! Repita a ordem.';
      }, 500);
    }
  }, 750);
}
function lightStone(c){
  const el = document.querySelector('.stone.'+c);
  el.classList.add('lit');
  beep(c);
  setTimeout(()=>el.classList.remove('lit'), 400);
}
function stoneClick(c){
  if(!accepting) return;
  lightStone(c);
  if(sequence[userStep] === c){
    userStep++;
    if(userStep === sequence.length){
      accepting = false;
      level++;
      document.getElementById('trilhaLevel').textContent = level;
      addStar(1);
      document.getElementById('trilhaMsg').textContent = 'Isso aí! Ganhou uma estrela ⭐ Próxima trilha...';
      sequence.push(colors[Math.floor(Math.random()*4)]);
      setTimeout(playSequence, 1200);
    }
  } else {
    accepting = false;
    document.getElementById('trilhaMsg').textContent = 'Quase lá! Vamos ver essa trilha de novo, com calma.';
    setTimeout(playSequence, 1500);
  }
}
let audioCtx;
function beep(c){
  try{
    audioCtx = audioCtx || new (window.AudioContext||window.webkitAudioContext)();
    const freqs = {sky:392, grass:330, sun:262, coral:220};
    const o = audioCtx.createOscillator();
    const g = audioCtx.createGain();
    o.frequency.value = freqs[c];
    o.type = 'sine';
    g.gain.value = 0.08;
    o.connect(g); g.connect(audioCtx.destination);
    o.start();
    o.stop(audioCtx.currentTime + 0.28);
  }catch(e){}
}

/* ---------- JARDIM DA ESPERA ---------- */
let chosenDuration = 20;
let jardimTimer = null;
function setDuration(sec, btn){
  chosenDuration = sec;
  document.querySelectorAll('#durationChoice button').forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected');
}
function plantSeed(){
  const btn = document.getElementById('jardimBtn');
  btn.disabled = true;
  document.getElementById('jardimMsg').textContent = 'A sementinha foi plantada. Vamos esperar juntos...';
  const scene = document.getElementById('plantScene');
  const circle = document.getElementById('breatheCircle');
  const bar = document.getElementById('jardimBar');
  const phrases = ['Respire fundo comigo...', 'Esperar também é uma habilidade.', 'Estamos quase lá...', 'Você está indo muito bem.'];
  let elapsed = 0;
  const totalMs = chosenDuration*1000;
  let phraseIdx = 0;
  const phraseTimer = setInterval(()=>{
    phraseIdx = (phraseIdx+1)%phrases.length;
    document.getElementById('jardimMsg').textContent = phrases[phraseIdx];
    circle.style.transform = circle.style.transform === 'scale(1.3)' ? 'scale(0.85)' : 'scale(1.3)';
  }, 4000);
  const step = 100;
  jardimTimer = setInterval(()=>{
    elapsed += step;
    const pct = Math.min(100, (elapsed/totalMs)*100);
    bar.style.width = pct+'%';
    if(pct > 33 && pct <= 66) scene.textContent = '🌿';
    if(pct > 66) scene.textContent = '🌷';
    if(elapsed >= totalMs){
      clearInterval(jardimTimer);
      clearInterval(phraseTimer);
      scene.textContent = '🌸';
      document.getElementById('jardimMsg').textContent = 'A flor desabrochou! Você esperou com calma. ⭐';
      addStar(1);
      btn.disabled = false;
      btn.textContent = 'Plantar outra sementinha';
      bar.style.width = '0%';
    }
  }, step);
}

/* ---------- CASCO FORTE (memory game) ---------- */
const memEmojis = ['🐢','🐸','🦋','🐝','🌸','🍄','🐌','🐟'];
let memState = [];
let flipped = [];
let lock = false;
let matchesFound = 0;
function setupMemory(){
  const pairs = [...memEmojis, ...memEmojis];
  pairs.sort(()=>Math.random()-0.5);
  memState = pairs.map((e,i)=>({id:i, emoji:e, flipped:false, matched:false}));
  flipped = [];
  matchesFound = 0;
  lock = false;
  document.getElementById('cascoMsg').textContent = 'Encontre os pares. Errar faz parte, é só continuar!';
  renderMemory();
}
function renderMemory(){
  const grid = document.getElementById('memGrid');
  grid.innerHTML = '';
  memState.forEach(card=>{
    const div = document.createElement('div');
    div.className = 'mcard' + (card.flipped||card.matched ? ' flipped' : '') + (card.matched ? ' matched' : '');
    div.textContent = (card.flipped||card.matched) ? card.emoji : '🍀';
    div.onclick = ()=>flipCard(card.id);
    grid.appendChild(div);
  });
}
function flipCard(id){
  if(lock) return;
  const card = memState.find(c=>c.id===id);
  if(card.flipped || card.matched) return;
  card.flipped = true;
  flipped.push(card);
  renderMemory();
  if(flipped.length===2){
    lock = true;
    setTimeout(()=>{
      if(flipped[0].emoji === flipped[1].emoji){
        flipped[0].matched = true;
        flipped[1].matched = true;
        matchesFound++;
        document.getElementById('cascoMsg').textContent = 'Achou um par! 🎉';
        if(matchesFound === memEmojis.length){
          document.getElementById('cascoMsg').textContent = 'Você terminou o jogo todo! Isso é força de vontade. ⭐';
          addStar(1);
        }
      } else {
        flipped[0].flipped = false;
        flipped[1].flipped = false;
        document.getElementById('cascoMsg').textContent = 'Não foi dessa vez. Vamos tentar de novo, sem pressa!';
      }
      flipped = [];
      lock = false;
      renderMemory();
    }, 800);
  }
}

/* ---------- init ---------- */
loadProgress();
setupMemory();
</script>
</body>
</html>
